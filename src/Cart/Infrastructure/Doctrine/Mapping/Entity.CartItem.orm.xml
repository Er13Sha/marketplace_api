<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                                      https://doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
    <entity name="App\Cart\Domain\Entity\CartItem" table="cart_items">
        <id name="id" type="guid" column="id" length="36">
            <generator strategy="NONE"/>
        </id>
        <many-to-one field="cart" target-entity="App\Cart\Domain\Entity\Cart" inversed-by="items">
            <join-column name="cart_id" referenced-column-name="id" nullable="false" on-delete="CASCADE"/>
        </many-to-one>
        <field name="productId" type="product_id" column="product_id" length="36"/>
        <field name="quantity" type="integer"/>
        <field name="createdAt" type="datetime_immutable" column="created_at"/>
        <field name="updatedAt" type="datetime_immutable" column="updated_at"/>
    </entity>
</doctrine-mapping>
