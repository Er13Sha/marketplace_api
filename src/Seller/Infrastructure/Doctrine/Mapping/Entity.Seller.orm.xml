<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                                      https://doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
    <entity name="App\Seller\Domain\Entity\Seller" table="sellers">
        <id name="id" type="guid" column="id" length="36">
            <generator strategy="NONE"/>
        </id>
        <field name="ownerUserId" type="guid" column="owner_user_id" unique="true"/>
        <field name="displayName" type="string" column="display_name" length="255"/>
        <field name="legalType" type="string" column="legal_type" length="32"/>
        <field name="taxId" type="string" column="tax_id" length="64"/>
        <field name="phoneNumber" type="string" column="phone_number" length="32"/>
        <field name="address" type="string" length="500"/>
        <field name="bankName" type="string" column="bank_name" length="255" nullable="true"/>
        <field name="bankAccount" type="string" column="bank_account" length="64"/>
        <field name="description" type="text" nullable="true"/>
        <field name="status" type="string" length="32"/>
        <field name="createdAt" type="datetime_immutable" column="created_at"/>
        <field name="updatedAt" type="datetime_immutable" column="updated_at"/>
    </entity>
</doctrine-mapping>
