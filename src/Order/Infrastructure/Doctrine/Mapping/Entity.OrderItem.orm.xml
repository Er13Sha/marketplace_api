<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                                      https://doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
    <entity name="App\Order\Domain\Entity\OrderItem" table="order_items">
        <id name="id" type="guid" column="id" length="36">
            <generator strategy="NONE"/>
        </id>
        <many-to-one field="parentOrder" target-entity="App\Order\Domain\Entity\Order" inversed-by="items">
            <join-column name="order_id" referenced-column-name="id" nullable="false" on-delete="CASCADE"/>
        </many-to-one>
        <field name="productId" type="guid" column="product_id" length="36"/>
        <field name="productSku" type="string" column="product_sku" length="64"/>
        <field name="productName" type="string" column="product_name" length="255"/>
        <field name="priceAmount" type="integer" column="price_amount"/>
        <field name="currency" type="string" length="3"/>
        <field name="quantity" type="integer"/>
        <field name="lineTotal" type="integer" column="line_total"/>
        <field name="reservationId" type="guid" column="reservation_id" length="36" nullable="true"/>
        <field name="createdAt" type="datetime_immutable" column="created_at"/>
    </entity>
</doctrine-mapping>
