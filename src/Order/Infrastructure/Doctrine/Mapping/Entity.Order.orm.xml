<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                                      https://doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
    <entity name="App\Order\Domain\Entity\Order" table="orders">
        <id name="id" type="guid" column="id" length="36">
            <generator strategy="NONE"/>
        </id>
        <field name="userId" type="guid" column="user_id" length="36"/>
        <field name="cartId" type="guid" column="cart_id" length="36" nullable="true"/>
        <field name="status" type="string" length="32"/>
        <field name="total" type="integer"/>
        <field name="currency" type="string" length="3"/>
        <one-to-many field="items" target-entity="App\Order\Domain\Entity\OrderItem" mapped-by="parentOrder" orphan-removal="true">
            <cascade>
                <cascade-persist/>
                <cascade-remove/>
            </cascade>
            <order-by>
                <order-by-field name="createdAt" direction="ASC"/>
            </order-by>
        </one-to-many>
        <field name="createdAt" type="datetime_immutable" column="created_at"/>
        <field name="updatedAt" type="datetime_immutable" column="updated_at"/>
    </entity>
</doctrine-mapping>
