<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                                      https://doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
    <entity name="App\Auth\Domain\Entity\User" table="auth_users">
        <id name="id" type="guid" column="id" length="36">
            <generator strategy="NONE"/>
        </id>
        <field name="email" type="string" length="180" unique="true"/>
        <field name="phoneNumber" type="string" column="phone_number" length="32" nullable="true" unique="true"/>
        <field name="passwordHash" type="string" column="password_hash" length="255"/>
        <field name="roles" type="json"/>
        <field name="createdAt" type="datetime_immutable" column="created_at"/>
        <field name="updatedAt" type="datetime_immutable" column="updated_at"/>
    </entity>
</doctrine-mapping>
